        public MuseumSystem()
        {
            Console.WriteLine($"Which school or group came?");
            string NameInput = Console.ReadLine();

            Console.WriteLine($"How many people in this group?");
            int PeopleInput = Convert.ToInt32(Console.ReadLine());

            Console.WriteLine($"How much ticket price per person?");
            double PriceInput = Convert.ToDouble(Console.ReadLine());

            Console.WriteLine($"How much donation did this group?");
